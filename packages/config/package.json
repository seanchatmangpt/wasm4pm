{
  "name": "@pictl/config",
  "version": "26.4.8",
  "description": "Configuration management system for wasm4pm with Zod schemas and provenance tracking",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./resolver": {
      "import": "./dist/resolver.js",
      "types": "./dist/resolver.d.ts"
    },
    "./provenance": {
      "import": "./dist/provenance.js",
      "types": "./dist/provenance.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./hash": {
      "import": "./dist/hash.js",
      "types": "./dist/hash.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@pictl/contracts": "workspace:*",
    "blake3": "^2.1.1",
    "toml": "^3.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "config",
    "configuration",
    "zod",
    "validation",
    "provenance",
    "blake3",
    "hash",
    "wasm4pm"
  ],
  "author": "Sean Chatman",
  "license": "SEE LICENSE IN LICENSE"
}
