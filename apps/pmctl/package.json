{
  "name": "@wasm4pm/pmctl",
  "version": "26.4.7",
  "description": "CLI tool for process mining and workflow discovery",
  "type": "module",
  "bin": {
    "pmctl": "./dist/bin/pmctl.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@wasm4pm/config": "workspace:*",
    "@wasm4pm/engine": "workspace:*",
    "@wasm4pm/ml": "workspace:^",
    "@wasm4pm/contracts": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "process-mining",
    "cli",
    "discovery",
    "workflow"
  ],
  "author": "Sean Chatman",
  "license": "MIT"
}
