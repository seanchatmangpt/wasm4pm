/** Underscore form — used in config.prediction.tasks and @wasm4pm/config schema enum */
export const PREDICTION_TASKS = [
{% for row in results %}  '{{ row.taskId }}'{{ "," if not loop.last }}
{% endfor %}] as const;

export type PredictionTask = typeof PREDICTION_TASKS[number];

/** Hyphen form — used as `pmctl predict <task>` CLI argument */
export const VALID_PREDICT_CLI_TASKS = [
{% for row in results %}  '{{ row.cliSlug }}'{{ "," if not loop.last }}
{% endfor %}] as const;

export type PredictCliTask = typeof VALID_PREDICT_CLI_TASKS[number];

/** Maps CLI slug (hyphen) → config task ID (underscore) */
export const CLI_SLUG_TO_TASK_ID: Record<string, PredictionTask> = {
{% for row in results %}  '{{ row.cliSlug }}': '{{ row.taskId }}'{{ "," if not loop.last }}
{% endfor %}};

/** Maps config task ID (underscore) → CLI slug (hyphen) */
export const TASK_ID_TO_CLI_SLUG: Record<PredictionTask, string> = {
{% for row in results %}  {{ row.taskId }}: '{{ row.cliSlug }}'{{ "," if not loop.last }}
{% endfor %}};
