{
  "name": "@wasm4pm/sinks",
  "version": "26.4.5",
  "description": "Output sinks and exporters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@wasm4pm/engine": "workspace:*",
    "@wasm4pm/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "sinks",
    "exporters",
    "outputs"
  ],
  "author": "Sean Chatman",
  "license": "MIT"
}
