{
  "observability": {
    "enabled": true,
    "json_logs": {
      "enabled": true,
      "path": "./logs/events.jsonl",
      "format": "jsonl",
      "buffer_size": 1000
    },
    "cli_output": {
      "enabled": true,
      "level": "info",
      "quiet": false,
      "verbose": false,
      "progress_bar": true,
      "color": true
    },
    "otel": {
      "enabled": true,
      "service_name": "wasm4pm-lab",
      "exporters": {
        "traces": {
          "type": "jaeger",
          "enabled": true,
          "endpoint": "http://localhost:14268/api/traces",
          "timeout_ms": 5000,
          "batch_size": 100
        },
        "metrics": {
          "type": "prometheus",
          "enabled": true,
          "port": 8888,
          "interval_ms": 10000
        },
        "logs": {
          "type": "otlp",
          "enabled": true,
          "endpoint": "http://localhost:4317",
          "protocol": "grpc"
        }
      }
    },
    "secret_redaction": {
      "enabled": true,
      "patterns": [
        "password",
        "api_key",
        "secret",
        "token",
        "bearer",
        "oauth"
      ],
      "preserve_patterns": [
        "email"
      ]
    },
    "event_filtering": {
      "log_level": "info",
      "enable_debug": false,
      "enable_trace": false,
      "sample_rate": 1.0
    }
  }
}
