{
  "name": "@pictl/ml",
  "version": "26.4.8",
  "description": "Native ML-powered process mining analysis — classification, clustering, forecasting, anomaly detection, PCA",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "machine-learning",
    "process-mining",
    "classification",
    "clustering",
    "forecasting",
    "anomaly-detection",
    "pca",
    "wasm4pm",
    "pictl"
  ],
  "author": "Sean Chatman",
  "license": "SEE LICENSE IN LICENSE"
}
