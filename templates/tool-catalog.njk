/**
 * wasm4pm tool catalog — {{ results | length }} MCP tools derived from the O* surface ontology.
 *
 * Source of truth: ontology/core/wasm4pm_surface.ttl
 * Regenerate with: unrdf sync
 *
 * Do not edit this file by hand. Change the ontology, then re-sync.
 */

export const TOOL_COUNT = {{ results | length }};

export const TOOL_IDS = [
{% for row in results %}  "{{ row.toolId }}"{{ "," if not loop.last }}
{% endfor %}] as const;

export type ToolId = typeof TOOL_IDS[number];

export interface ToolSpec {
  label: string;
  tier: 'FastTier' | 'MediumTier' | 'SlowTier';
  inputFormat: string;
  outputFormat: string;
  supportsOCEL: boolean;
  requiresHandle: boolean;
  durationMs: number;
  endpoint: string;
}

export const TOOLS: Record<ToolId, ToolSpec> = {
{% for row in results %}  {{ row.toolId }}: {
    label: "{{ row.label }}",
    tier: "{{ row.tier }}",
    inputFormat: "{{ row.inputFormat }}",
    outputFormat: "{{ row.outputFormat }}",
    supportsOCEL: {{ "true" if row.supportsOCEL == "true" else "false" }},
    requiresHandle: {{ "true" if row.requiresHandle == "true" else "false" }},
    durationMs: {{ row.durationMs }},
    endpoint: "{{ row.endpoint }}",
  }{{ "," if not loop.last }}
{% endfor %}};

/**
 * Returns all tools belonging to the given performance tier.
 */
export function getToolsByTier(tier: 'FastTier' | 'MediumTier' | 'SlowTier'): ToolSpec[] {
  return TOOL_IDS.filter((id) => TOOLS[id].tier === tier).map((id) => TOOLS[id]);
}

/**
 * Returns all tools that natively handle Object-Centric Event Logs (OCEL 2.0).
 */
export function getOCELTools(): ToolSpec[] {
  return TOOL_IDS.filter((id) => TOOLS[id].supportsOCEL).map((id) => TOOLS[id]);
}

/**
 * Returns all tools that require a pre-loaded in-process WASM handle.
 * Call load_ocel or discover_dfg first to obtain a handle.
 */
export function getHandleTools(): ToolSpec[] {
  return TOOL_IDS.filter((id) => TOOLS[id].requiresHandle).map((id) => TOOLS[id]);
}

