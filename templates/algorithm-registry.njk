/**
 * wasm4pm kernel algorithm registry — {{ results | length }} discovery algorithms.
 *
 * Source of truth: /Users/sac/ostar/plugins/wasm4pm/ontology/surface.ttl (KernelAlgorithm individuals)
 * Regenerate with: unrdf sync  (or: pnpm generate)
 *
 * DO NOT EDIT THIS FILE BY HAND. Change the ontology, then re-sync.
 */

{% set seen = [] %}
{% set algorithms = [] %}
{% for row in results %}
  {% if row.kernelId not in seen %}
    {% set _ = seen.push(row.kernelId) %}
    {% set _ = algorithms.push(row) %}
  {% endif %}
{% endfor %}

export const ALGORITHM_IDS = [
{% for algo in algorithms %}  '{{ algo.kernelId }}'{{ "," if not loop.last }}
{% endfor %}] as const;

export type AlgorithmId = typeof ALGORITHM_IDS[number];

/** Maps kernel registry ID → planner PlanStepType string value */
export const ALGORITHM_ID_TO_STEP_TYPE: Record<string, string> = {
{% for algo in algorithms %}  {{ algo.kernelId }}: '{{ algo.plannerStepType }}'{{ "," if not loop.last }}
{% endfor %}};

/** Maps kernel registry ID → output model type */
export const ALGORITHM_OUTPUT_TYPES: Record<string, string> = {
{% for algo in algorithms %}  {{ algo.kernelId }}: '{{ algo.outputType }}'{{ "," if not loop.last }}
{% endfor %}};

/** Maps kernel registry ID → CLI alias for pmctl run/compare */
export const ALGORITHM_CLI_ALIASES: Record<string, string> = {
{% for algo in algorithms %}  {{ algo.kernelId }}: '{{ algo.cliAlias }}'{{ "," if not loop.last }}
{% endfor %}};

/** Maps kernel registry ID → display name (from ontology skos:prefLabel) */
export const ALGORITHM_DISPLAY_NAMES: Record<string, string> = {
{% for algo in algorithms %}  {{ algo.kernelId }}: '{{ algo.label }}'{{ "," if not loop.last }}
{% endfor %}};

/**
 * Returns the primary algorithm IDs for a given execution profile.
 * Profile → algorithm selection derived from wasm4pm:supportedIn ontology triples.
 */
export function getProfileAlgorithms(profile: string): string[] {
  const map: Record<string, string[]> = {
{% for profileId in ['fast', 'balanced', 'quality', 'stream'] %}    {{ profileId }}: [{% for row in results %}{% if row.profileId == profileId %}'{{ row.kernelId }}', {% endif %}{% endfor %}],
{% endfor %}  };
  return map[profile.toLowerCase()] ?? map['balanced']!;
}
