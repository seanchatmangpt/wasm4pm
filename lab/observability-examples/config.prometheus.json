{
  "observability": {
    "enabled": true,
    "json_logs": {
      "enabled": true,
      "path": "./logs/prometheus.jsonl",
      "format": "jsonl",
      "buffer_size": 2000
    },
    "cli_output": {
      "enabled": true,
      "level": "info",
      "quiet": false,
      "verbose": false,
      "progress_bar": true,
      "color": true
    },
    "otel": {
      "enabled": true,
      "service_name": "wasm4pm-prometheus",
      "exporters": {
        "traces": {
          "type": "otlp",
          "enabled": true,
          "endpoint": "http://localhost:4317",
          "protocol": "grpc"
        },
        "metrics": {
          "type": "prometheus",
          "enabled": true,
          "port": 8889,
          "path": "/metrics",
          "interval_ms": 5000
        },
        "logs": {
          "type": "otlp",
          "enabled": false
        }
      }
    },
    "secret_redaction": {
      "enabled": true,
      "patterns": [
        "password",
        "api_key",
        "secret",
        "token",
        "bearer",
        "oauth"
      ],
      "preserve_patterns": [
        "email"
      ]
    },
    "event_filtering": {
      "log_level": "info",
      "enable_debug": false,
      "enable_trace": false,
      "sample_rate": 0.5
    }
  }
}
