{
  "name": "@wasm4pm/lab-cli-tests",
  "version": "26.4.5",
  "description": "CLI validation test suite for @wasm4pm/pmctl",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "vitest run --reporter=verbose",
    "test:run-cmd": "vitest run -t 'Run Command'",
    "test:watch-cmd": "vitest run -t 'Watch Command'",
    "test:status-cmd": "vitest run -t 'Status Command'",
    "test:explain-cmd": "vitest run -t 'Explain Command'",
    "test:init-cmd": "vitest run -t 'Init Command'",
    "test:exit-codes": "vitest run -t 'Exit Codes'",
    "test:config": "vitest run -t 'Configuration Resolution'",
    "clean": "rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "@seanchatmangpt/pictl": "^26.4.9"
  },
  "keywords": [
    "cli",
    "validation",
    "testing",
    "process-mining",
    "conformance"
  ],
  "author": "Sean Chatman",
  "license": "MIT"
}
