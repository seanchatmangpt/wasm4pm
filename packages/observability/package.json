{
  "name": "@wasm4pm/observability",
  "version": "26.4.7",
  "description": "Optional non-blocking OTEL observability layer for wasm4pm",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "observability",
    "otel",
    "opentelemetry",
    "tracing",
    "process-mining"
  ],
  "author": "Sean Chatman",
  "license": "MIT"
}
